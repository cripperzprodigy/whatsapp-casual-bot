# ==============================================================================
# WHATSAPP GATEWAY (Native Node.js Microservice)
# ==============================================================================
# The default internal gateway URL. You usually do not need to change this.
WHATSAPP_GATEWAY_URL=http://localhost:3000

# ==============================================================================
# WHATSAPP GATEWAY CACHE
# ==============================================================================
WHATSAPP_CACHE_MAX_SIZE=5000
WHATSAPP_CACHE_TTL_SECONDS=300

# Port for the Node.js service to listen on (Default: 3000)
# PORT=3000

# Endpoint the Node.js service hits to pass payloads back to Python (Default: http://localhost:8000/webhook/whatsapp)
# PYTHON_WEBHOOK_URL=http://localhost:8000/webhook/whatsapp

# Path where whatsapp-web.js stores its authentication files (Default: ./.wwebjs_auth)
# WHATSAPP_SESSION_PATH=./.wwebjs_auth

# ==============================================================================
# SECURITY & IDENTITY
# ==============================================================================
# Bot Identity (Important: Prevents the bot from responding to itself).
# Provide the number without + or spaces, including country code (e.g. 1234567890)
BOT_NUMBER=YOUR_BOT_PHONE_NUMBER_HERE

# Auto-sync bot number from the WhatsApp Gateway at startup if it mismatches BOT_NUMBER. (Default: False)
AUTO_SYNC_BOT_NUMBER=False
# Cache TTL (seconds) for the bot identity fetched from the gateway. (Default: 300)
BOT_IDENTITY_CACHE_TTL=300

# Bootstrap Owner ID (Optional). If provided, assigns master owner role automatically.
# Format: WhatsApp JID (e.g., 1234567890@s.whatsapp.net)
# BOT_OWNER_ID=

# Security Whitelist (Comma-separated list of allowed chat IDs, e.g. 123@g.us,456@c.us).
# Leave empty to allow the bot to respond in ALL chats it is added to.
WHITELISTED_CHATS=
# When True, the bot will only respond to chats listed in WHITELISTED_CHATS.
# When False (default), the whitelist is ignored and the bot responds everywhere.
ENFORCE_WHITELIST=False

# ==============================================================================
# AUTO-TRANSLATION (GLOBAL DEFAULTS)
# ==============================================================================
# These act as the defaults if a specific chat has not explicitly overridden them via commands.
# Default: false — translation is OFF globally until Owner enables via !globaltrans on
GLOBAL_AUTO_TRANSLATE=False
GLOBAL_TARGET_LANGUAGE=en
# EN/ID/MS Linguistic Sphere: these languages are NEVER translated between each other (ADR-028)
GLOBAL_IGNORED_LANGUAGES=en,id,ms

# Translation Sensitivity
# TRANSLATION_MIN_LENGTH controls the minimum characters required before attempting translation
TRANSLATION_MIN_LENGTH=4
TRANSLATION_CONFIDENCE_THRESHOLD=0.70
# Languages treated as mutually equivalent (no translation between them)
# Part of the EN/ID/MS Linguistic Sphere (ADR-028)
TRANSLATION_EQUIVALENT_LANGS=en,id,ms
TRANSLATION_CHUNK_SIZE=2000
TRANSLATION_MAX_CHUNKS=5

# External keyword file for linguistic sphere detection (ADR-029)
# One keyword per line, # for comments. Edit to add/remove colloquial words.
TRANSLATION_SKIP_KEYWORDS_FILE=data/translation_skip_keywords.txt

# The warning string rendered when an AI translation API call fails (Default is below)
# MSG_TRANSLATION_ERROR=[⚠️ Translation service temporarily unavailable]

# ==============================================================================
# CONTACT SYNCHRONIZATION
# ==============================================================================
# If true, the bot will silently fetch and store group member statuses in bot.db.
AUTO_SYNC_CONTACTS=True

# Directory where CSV/Markdown exports will be generated. (Default: exports/groups)
CONTACTS_EXPORT_DIR=exports/groups

# Throttle for generating the physical file export to prevent disk lag in busy chats (Seconds, Default: 60)
# ROSTER_EXPORT_THROTTLE_SECONDS=60

# ==============================================================================
# AI CONFIGURATION (UNIFIED OPENAI-COMPATIBLE CLIENT)
# ==============================================================================
# This single configuration block supports ANY provider that follows the OpenAI API standard.
# This includes Local AIs (LM Studio, Ollama, vLLM) and Cloud AIs (OpenAI, Groq, Together).

# Example 1: LM STUDIO SETUP (Uncomment these to use LM Studio)
# LLM_ENDPOINT=http://192.168.1.5:1234/v1
# LLM_API_KEY=lm-studio
# DEFAULT_MODEL_NAME=google/gemma-4-12b-qat

# Example 2: OPENAI SETUP (Uncomment these to use OpenAI)
# LLM_ENDPOINT=https://api.openai.com/v1
# LLM_API_KEY=sk-proj-YOUR_API_KEY_HERE
# DEFAULT_MODEL_NAME=gpt-4o

# Max context tokens generated per response (Default: 8192)
# NOTE: For high-context local models (like reasoning models with up to 131k context),
# you can safely increase this up to 131072.
LLM_MAX_TOKENS=8192
MAX_CONTEXT_MESSAGES=50
LLM_TIMEOUT_SECONDS=180

# ==============================================================================
# SEARCH CONFIGURATION
# ==============================================================================
# Search Mode: "hybrid", "searxng", "duckduckgo" (Default: hybrid)
SEARCH_PROVIDER_MODE=hybrid
# SEARXNG_BASE_URL=http://your-searxng-instance:8080
# Enable or disable the !s agentic search feature.
ENABLE_AGENTIC_SEARCH=true
# Number of search results to fetch per query.
SEARCH_MAX_RESULTS=5
# Delay (seconds) between iterative API calls to respect rate limits.
OPENROUTER_RATE_LIMIT_DELAY=2.0
# Maximum refinement iterations for !s agentic search.
AGENTIC_MAX_ITERATIONS=3
# Number of search results to fetch per query.
SEARCH_RESULTS_PER_QUERY=10

# ==============================================================================
# DEEP CRAWL CONFIGURATION
# ==============================================================================
# Enable or disable the !sc deep crawl search feature.
DEEP_CRAWL_ENABLED=true
# Maximum number of URLs to crawl per !sc query (1-20).
DEEP_CRAWL_MAX_URLS=5
# Legacy timeout variable.
DEEP_CRAWL_TIMEOUT_SECONDS=10
# Timeout for fetching individual websites (seconds).
CRAWL_TIMEOUT_SECONDS=15
# Timeout for LLM synthesis (seconds). Increase for complex deep crawl tasks.
LLM_TIMEOUT_SECONDS=300
# Maximum total characters of context to send to LLM. Prevents context overflow.
MAX_TOTAL_CONTEXT_CHARS=15000
# If true, fallback to snippet search (!s) if deep crawl (!sc) fails completely.
FALLBACK_TO_SNIPPETS=true

# LLM Timeout for Search Synthesis (seconds) - Allow time for large context processing
LLM_SEARCH_TIMEOUT=90
# Individual Site Crawl Timeout (seconds)
CRAWL_CONNECTION_TIMEOUT=10
# Total Crawl Operation Timeout (seconds)
CRAWL_TOTAL_TIMEOUT=30
# ==============================================================================
# CHATTY FEATURE & PERSISTENT MEMORY (RAG)
# ==============================================================================
# Default chatty mode for new users in 1:1 Direct Messages (Boolean, Default: True)

# Default chatty mode for newly joined Groups (Boolean, Default: False to avoid spam)
CHATTY_GROUP_DEFAULT=False

# Enable AI auto-summarization of chat history into profile.json state vectors
DYNAMIC_SYSTEM_PROMPT=True

# Local Sentence Transformer model used for generating vector embeddings
# Default is 'all-MiniLM-L6-v2'. If on a low-end system, use 'all-MiniLM-L3-v2'.
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Allow the bot to process images via Vision LLM tasks
VISION_ENABLED=True

# ── RAG (Retrieval-Augmented Generation) Configuration ──────────────────────
# Master toggle: set False to disable all ChromaDB writes and retrieval.
ENABLE_RAG_INGESTION=True
# Number of past messages retrieved from ChromaDB per query (Default: 5).
RAG_TOP_K=5
# Temporal decay TTL: exclude messages older than N days from standard queries.
# Set to 0 to disable TTL filtering (retrieve all history). Historical queries
# ("last month", "remember when") bypass this filter automatically.
RAG_DEFAULT_TTL_DAYS=7

# ── Hybrid Context (ADR-040) ───────────────────────────────────────────────
# Number of recent messages injected directly into the prompt as raw text,
# bypassing RAG for short-term conversational continuity. Set 0 to disable.
MEMORY_IMMEDIATE_BUFFER_SIZE=5
# Recency decay alpha for RAG re-ranking: final_score = similarity / (1 + alpha * days_since_msg).
# 0.0 = no recency bias (pure semantic similarity). Higher values (e.g. 1.0, 2.0)
# make the bot prioritise very recent conversations over older semantically-similar ones.
MEMORY_RECENCY_ALPHA=0.5

# ── Chatty Web Search Integration (ADR-041) ─────────────────────────────────
# When True, the AI may auto-search the web and blend results naturally into
# replies. Toggle per-chat via !chatty search on|off.
CHATTY_SEARCH_DEFAULT=True
# Max seconds to wait for a natural-language-triggered search to complete.
# If exceeded, a "search took too long" message is sent instead of hanging.
CHATTY_SEARCH_TIMEOUT_SECONDS=15

# Chatty Frequency Defaults
CHATTY_DEFAULT=True              # Default Chatty status for Direct Messages
CHATTY_GROUP_DEFAULT=False       # Default Chatty status for Groups
CHATTY_DEFAULT_FREQUENCY=10      # Respond every X messages in group
CHATTY_DEFAULT_BURST=1           # Number of replies per trigger
CHATTY_DELAY_MIN=5               # Minimum seconds to wait before replying (human simulation)
CHATTY_DELAY_MAX=10              # Maximum seconds to wait before replying
CHATTY_DELAY_MODE=debounce       # Delay strategy: 'debounce' (reset timer on new msg) or 'throttle' (fixed timer from first msg)
# Languages supported by the Chatty AI engine for auto-selection.
# Includes 'zh' for Chinese (Simplified & Traditional) per ADR-039.
CHATTY_ENABLED_LANGUAGES=en,id,ms,zh

# Language Defaults
DEFAULT_GROUP_LANGUAGE=en        # Fallback for groups if detection fails
DEFAULT_DM_LANGUAGE=en           # Fallback for new DMs

# ==============================================================================
# SYSTEM & DATABASE
# ==============================================================================
# SQLAlchemy connection string (Default is local SQLite db: sqlite:///./bot.db)
# DATABASE_URL=sqlite:///./bot.db

# Global Logging Level (INFO, DEBUG, ERROR)
LOG_LEVEL=INFO

# Maximum incoming messages buffered in memory for AI summarization tasks (Default: 200)
MESSAGE_BUFFER_SIZE=200

# Number of recent messages to summarize (Range: 10-2000)
# Higher values provide more context but increase token usage.
SUMMARY_MESSAGE_LIMIT=500

# Webhook rate limiting per minute for incoming messages (Default: 60)
WEBHOOK_RATE_LIMIT=60

# ==============================================================================
# SPAM & FLOOD CONTROL (DIRECT MESSAGES)
# ==============================================================================
# Defines how many unprompted DMs the bot can fire before ignoring the user
PM_FLOOD_LIMIT=10
PM_FLOOD_INTERVAL_SECONDS=60
