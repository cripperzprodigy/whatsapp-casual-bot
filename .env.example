# ==============================================================================
# WHATSAPP GATEWAY (Native Node.js Microservice)
# ==============================================================================
# The default internal gateway URL. You usually do not need to change this.
WHATSAPP_GATEWAY_URL=http://localhost:3000

# ==============================================================================
# SECURITY & IDENTITY
# ==============================================================================
# Bot Identity (Important: Prevents the bot from responding to itself).
# Provide the number without + or spaces, including country code (e.g. 1234567890)
BOT_NUMBER=1234567890

# Security Whitelist (Comma-separated list of allowed chat IDs, e.g. 123@g.us,456@c.us).
# Leave empty to allow the bot to respond in ALL chats it is added to.
WHITELISTED_CHATS=

# ==============================================================================
# AUTO-TRANSLATION (GLOBAL DEFAULTS)
# ==============================================================================
# These act as the defaults if a specific chat has not explicitly overridden them via commands.
GLOBAL_AUTO_TRANSLATE=True
GLOBAL_TARGET_LANGUAGE=en
GLOBAL_IGNORED_LANGUAGES=en,id

# ==============================================================================
# CONTACT SYNCHRONIZATION
# ==============================================================================
AUTO_SYNC_CONTACTS=True

# ==============================================================================
# AI CONFIGURATION (LM STUDIO / LOCAL LLM SETUP)
# ==============================================================================
# Set this to True to tell the bot to route Translation and Summarization tasks to your Local AI.
USE_LOCAL_LLM=True

# The Local API Endpoint. For LM Studio, this is usually http://<ip>:1234/v1
LOCAL_LLM_ENDPOINT=http://192.168.1.5:1234/v1

# The API Token generated by your local instance.
LOCAL_LLM_API_KEY=sk-lm-ld14ZWB6:IGF41IWaT2JoJlWM1PKu

# The exact model identifier loaded in your LM Studio instance.
DEFAULT_MODEL_NAME_LOCAL=google/gemma-4-12b-qat

# ==============================================================================
# CLOUD LLM FALLBACK (Optional)
# ==============================================================================
# If the local LLM fails or is turned off, the bot can fallback to a cloud provider like OpenAI.
# Leave blank if you only want to use LM Studio.
CLOUD_LLM_ENDPOINT=https://api.openai.com/v1
CLOUD_LLM_API_KEY=
DEFAULT_MODEL_NAME_CLOUD=gpt-3.5-turbo
