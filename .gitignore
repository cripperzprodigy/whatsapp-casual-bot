# ==============================================================================
# SECURITY REMINDER: Never commit .env files, API keys, or credentials to version control.
# Always use .env.example or equivalent for template variables.
# ==============================================================================

# ------------------------------------------------------------------------------
# ENVIRONMENT VARIABLES & SECRETS
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env-example
*.key
*.pem
*.cert
credentials.json
client_secret.json
secrets.toml
# Any other custom auth tokens
.wwebjs_auth/
.wwebjs_cache/

# ------------------------------------------------------------------------------
# PYTHON ARTIFACTS
# ------------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]
*$py.class
*.so

# Distribution / packaging
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# ------------------------------------------------------------------------------
# VIRTUAL ENVIRONMENTS
# ------------------------------------------------------------------------------
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/
.python-version

